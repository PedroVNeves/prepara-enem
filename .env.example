SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase Postgres via pooler transaction-mode (Supavisor/pgbouncer).
# Sem essa variável, o projeto cai para sqlite local (dev/testes).
DATABASE_URL=postgres://user:password@host:6543/postgres

GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-flash-lite-latest
GEMINI_MODEL_PRO=gemini-pro-latest

# Liga o APScheduler em processo (fila de redação + recalibração TRI semanal).
# Deixe False localmente/em testes; True só no processo web real (produção).
ENABLE_SCHEDULER=False

# E-mail transacional (reset de senha). Sem EMAIL_HOST, cai para o console
# backend (imprime o e-mail no terminal) — bom para dev. Em produção, use o
# SMTP relay de um provedor barato (Resend, Brevo, etc).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Prepara ENEM <no-reply@preparaenem.example.com>
